# Copy this file to .env.local and fill in real values when wiring live backends.
# All variables are OPTIONAL for the UI-only v1 (it runs on mocked battlecards).
# NEVER commit secrets to this file. .env.local is gitignored.

# ---- Cisco Circuit AI (general chat) ----
# OAuth2 client credentials from your Cisco IDM tenant.
CIRCUIT_CLIENT_ID=
CIRCUIT_CLIENT_SECRET=
CIRCUIT_APP_KEY=
CIRCUIT_MODEL=gpt-5-nano
CIRCUIT_TOKEN_URL=https://id.cisco.com/oauth2/default/v1/token
CIRCUIT_BASE_URL=https://chat-ai.cisco.com/openai/deployments
# Optional: Okta often requires a scope for client_credentials.
# CIRCUIT_SCOPE=
# Optional: Okta custom auth servers / Cisco Apigee gateways may require an
# explicit audience claim on the token (passed as `audience=` in the token request).
# CIRCUIT_AUDIENCE=
# Optional: override the Azure-OpenAI api-version (default: 2024-12-01-preview).
# CIRCUIT_API_VERSION=2024-12-01-preview

# ---- Cisco Circuit internal search / RAG (pending approval) ----
CIRCUIT_RAG_URL=
CIRCUIT_RAG_KEY=

# ---- Cisco Docs AI (REST endpoint, used by the in-app "Ask Cisco Docs" panel) ----
# Sign up at https://docs-ai.cloudapps.cisco.com/register to get an API key.
# IMPORTANT: never commit the real key. Place real values only in .env.local.
CISCO_DOCS_API_URL=https://docs-ai.cloudapps.cisco.com/api/v1/docs/ask
CISCO_DOCS_API_KEY=
# Optional: override the default 15s timeout (in milliseconds).
# CISCO_DOCS_TIMEOUT_MS=15000

# ---- Other MCP servers (not yet enabled) ----
CISCO_DOCS_MCP_URL=
CDETS_MCP_URL=
CDETS_MCP_TOKEN=
WEBEX_MCP_URL=
WEBEX_MCP_TOKEN=

# Behavior:
#   true  → always serve from authored mocked battlecards (instant; v1 default).
#   false → authored mocks still serve instantly; products without one are
#           synthesized live by Cisco Circuit.
USE_MOCK_BATTLECARDS=true

# ---- Cisco Data RAG API (genai-ext-rag / context_inference) ----
# Bring-your-own-app RAG over Cisco product documentation, returns markdown with
# numbered [N](url) citations — same response shape as Cisco Docs AI, so the
# existing parseDocsAnswer parser is drop-in compatible.
#
# Auth: short-lived OAuth2 bearer token from id.cisco.com (same flow as Circuit).
# Reuses CIRCUIT_CLIENT_ID / CIRCUIT_CLIENT_SECRET unless your Okta tenant
# requires a dedicated app for the RAG scope.
CISCO_RAG_URL=https://chat-ai.cisco.com/genai-ext-rag/api/v2.0/context_inference
CISCO_RAG_APP_ID=
CISCO_RAG_USER_ID=
# Optional: dedicated Okta client if your tenant requires a separate app for RAG.
# CISCO_RAG_CLIENT_ID=
# CISCO_RAG_CLIENT_SECRET=
# Optional: override the default 30s timeout (in milliseconds).
# CISCO_RAG_TIMEOUT_MS=30000

# ---- Docs backend selector ----
# Which backend powers the "Live highlights" and "Where the competitor falls short"
# sections on compare pages:
#   docs-ai   → Cisco Docs AI REST endpoint (default)
#   data-rag  → Cisco Data RAG (genai-ext-rag/context_inference)
# The Licensing section always uses the RAG (no equivalent on Docs AI).
MATRIX_DOCS_BACKEND=docs-ai

