# Copy this file to .env.local and fill in values as needed.
# NEVER commit secrets. .env.local is gitignored.

# -------------------------
# MODE 1: UI / MOCK ONLY
# -------------------------
# Keep this true to run Matrix without any API keys.
USE_MOCK_BATTLECARDS=true

# -------------------------
# MODE 2: LIVE BATTLECARDS (Circuit)
# -------------------------
# Set USE_MOCK_BATTLECARDS=false and provide these:
# - CIRCUIT_CLIENT_ID
# - CIRCUIT_CLIENT_SECRET
# - CIRCUIT_APP_KEY
# - CIRCUIT_TOKEN_URL
# - CIRCUIT_BASE_URL
# - CIRCUIT_MODEL
CIRCUIT_CLIENT_ID=
CIRCUIT_CLIENT_SECRET=
CIRCUIT_APP_KEY=
CIRCUIT_MODEL=gpt-5-nano
CIRCUIT_TOKEN_URL=https://id.cisco.com/oauth2/default/v1/token
CIRCUIT_BASE_URL=https://chat-ai.cisco.com/openai/deployments

# Optional Circuit auth knobs (only if your tenant needs them)
# CIRCUIT_SCOPE=
# CIRCUIT_AUDIENCE=

# Optional timeout for Circuit chat calls (ms)
# CIRCUIT_TIMEOUT_MS=120000

# -------------------------
# MODE 3: LIVE DOCS / INTEL
# -------------------------
# Backend selector for compare-page highlights/intel:
# - docs-ai (default)
# - data-rag
MATRIX_DOCS_BACKEND=docs-ai

# Option A: Cisco Docs AI backend (simplest)
CISCO_DOCS_API_URL=https://docs-ai.cloudapps.cisco.com/api/v1/docs/ask
CISCO_DOCS_API_KEY=
# Optional timeout (ms)
# CISCO_DOCS_TIMEOUT_MS=15000

# Option B: Cisco Data RAG backend
CISCO_RAG_URL=https://chat-ai.cisco.com/genai-ext-rag/api/v2.0/context_inference
CISCO_RAG_APP_ID=
CISCO_RAG_USER_ID=

# RAG auth:
# Either provide dedicated RAG credentials...
# CISCO_RAG_CLIENT_ID=
# CISCO_RAG_CLIENT_SECRET=
# CISCO_RAG_TOKEN_URL=
# ...or reuse Circuit credentials + CIRCUIT_TOKEN_URL above.

# Optional RAG auth knobs
# CISCO_RAG_SCOPE=
# CISCO_RAG_AUDIENCE=

# Optional RAG timeout (ms)
# CISCO_RAG_TIMEOUT_MS=30000

# -------------------------
# OPTIONAL / FUTURE (not used in current runtime paths)
# -------------------------
# CIRCUIT_RAG_URL=
# CIRCUIT_RAG_KEY=
# CISCO_DOCS_MCP_URL=
# CDETS_MCP_URL=
# CDETS_MCP_TOKEN=
# WEBEX_MCP_URL=
# WEBEX_MCP_TOKEN=

